{
  "name": "@gastar/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "pnpm prisma:generate && tsup src/index.ts --platform node --format esm --target node18 --out-dir dist --clean",
    "start": "node dist/index.js",
    "migrate:deploy": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ./prisma/schema.prisma",
    "start:deploy": "sh ./scripts/start-production.sh"
  },
  "dependencies": {
    "@gastar/shared": "workspace:*",
    "@prisma/client": "^6.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "prisma": "^6.6.0"
  }
}
